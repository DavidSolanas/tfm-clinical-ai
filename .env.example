# ============================================================
# Environment variables -- Copy to .env and fill in values
# cp .env.example .env
# ============================================================

# PubMed API (required for Entrez)
# Register at: https://www.ncbi.nlm.nih.gov/account/
NCBI_EMAIL=your_email@example.com
NCBI_API_KEY=your_api_key_here

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333

# MLflow (host port published by docker-compose: 5001 -> container 5000)
MLFLOW_TRACKING_URI=http://localhost:5001

# Hugging Face (optional, required for gated models such as LLaMA)
HF_TOKEN=hf_your_token_here

# Base model (adjust according to the decision log)
BASE_MODEL=meta-llama/Meta-Llama-3-8B-Instruct
EMBEDDING_MODEL=bioformers/bioformer-16L

# RAG
RAG_TOP_K=5
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=50

# Evaluation
OPENAI_API_KEY=openai_api_key_here
ANTHROPIC_API_KEY=anthropic_api_key_here